{
  "name": "ownertalk",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "npx patch-package",
    "start": "expo start --clear",
    "dev": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android-device": "expo run:android --device",
    "android-device-release": "expo run:android --device --variant release",
    "ios": "expo run:ios",
    "ios-device": "expo run:ios --device",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "build": "npx expo prebuild",
    "build-clean": "npx expo prebuild --clean",
    "build-ios": "EXPO_APPLE_TEAM_ID=AAAAAAA eas build --platform ios --profile production --auto-submit",
    "build-ios-dev": "EXPO_APPLE_TEAM_ID=AAAAAA eas build --platform ios --profile staging --auto-submit",
    "build-android": "eas build --platform android --profile production --auto-submit",
    "build-android-dev": "eas build --profile preview --platform android --local --clear-cache --output ~/project/http/ownertalk/ownertalk_release.apk"
  },
