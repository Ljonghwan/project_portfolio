{
  "name": "taseta",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --clear",
    "dev": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android-device": "expo run:android --device",
    "ios": "expo run:ios",
    "ios-device": "expo run:ios --device",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "build": "npx expo prebuild",
    "build-clean": "npx expo prebuild --clean",
    "build-ios": "EXPO_APPLE_TEAM_ID=AAAAA eas build --platform ios --profile production --auto-submit",
    "build-android": "eas build --profile production --platform android",
    "build-android-preview": "eas build --profile preview --platform android",
    "build-android-product-local": "eas build --profile production --platform android --local --clear-cache --output ~/project/http/taseta/Taseta_release.aab ",
    "build-android-local": "eas build --profile preview --platform android --local --clear-cache --output ~/project/http/taseta/Taseta_release.apk",
    "submit-ios": "eas submit --platform ios"
  },
